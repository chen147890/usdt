PORT=8088

# Generic discovery default.
PROJECT_URL=https://www.equium.xyz/
PROFILE_ID=equium

# Equium / Solana CLI miner.
# Use a high quality RPC for sustained mining; public Solana RPC rate-limits.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_KEYPAIR=runtime/keypairs/equium-id.json
# Optional: paste a 64-byte Solana private key as base58 or a no-space JSON array.
# When set, npm run deploy writes a local gitignored keypair file automatically.
# SOLANA_PRIVATE_KEY=
EQUIUM_THREADS=auto
EQUIUM_MAX_BLOCKS=0
EQUIUM_MAX_NONCES_PER_ROUND=4096
EQUIUM_START_TIME=03:00
EQUIUM_TIMEZONE=Asia/Shanghai
EQUIUM_PREFLIGHT_INTERVAL_SECONDS=300
EQUIUM_START_RETRY_SECONDS=30
EQUIUM_MIN_SOL_BALANCE=0.002

# Optional path to a prebuilt equium-miner binary.
# EQUIUM_MINER_BIN=/absolute/path/to/equium-miner
