PORT=8088

# Generic discovery default.
PROJECT_URL=https://www.equium.xyz/
PROFILE_ID=equium

# Equium / Solana CLI miner.
# Use a high quality RPC for sustained mining; public Solana RPC rate-limits.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_KEYPAIR=$HOME/.config/solana/id.json
EQUIUM_THREADS=auto
EQUIUM_MAX_BLOCKS=0
EQUIUM_MAX_NONCES_PER_ROUND=4096

# Optional path to a prebuilt equium-miner binary.
# EQUIUM_MINER_BIN=/absolute/path/to/equium-miner
